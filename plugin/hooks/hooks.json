{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); case \"$input\" in */.claude/*/worklog/*/skills/*/scripts/*) python \"${CLAUDE_PLUGIN_ROOT}/scripts/allow-skill-scripts.py\" <<< \"$input\" ;; esac"
          }
        ]
      }
    ]
  }
}
